    <Box>
      <Paper sx={{ p: 3, mb: 3, textAlign: 'center' }}>
        <Avatar src={user.image} sx={{ width: 100, height: 100, mx: 'auto', mb: 2 }}>{user.name?.charAt(0)}</Avatar>
