            size="small"
            color={order.paymentStatus === 'paid' ? 'success' : 'warning'}
          />
          <Chip
            label={`تاريخ الطلب: ${formatDate(order.createdAt)}`}
            size="small"
          />
        </Box>
      </Paper>
    </Box>
  );
}
